# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://bionic:bionic@localhost:5432/bionic_platform

# ── Server ────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-me-in-production

# ── Keycloak OIDC ─────────────────────────────────────────────
KEYCLOAK_URL=https://auth.bionicaisolutions.com
KEYCLOAK_REALM=Bionic
KEYCLOAK_CLIENT_ID=bionic-platform
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:5173/api/auth/callback

# ── Vault ─────────────────────────────────────────────────────
VAULT_ADDR=http://vault-internal.vault.svc.cluster.local:8200
VAULT_TOKEN=

# ── Kubernetes ────────────────────────────────────────────────
# In-cluster: leave blank (uses service account)
# Out-of-cluster: set path to kubeconfig
KUBECONFIG=~/.kube/config

# ── LiveKit ───────────────────────────────────────────────────
LIVEKIT_URL=wss://livekit.bionicaisolutions.com
LIVEKIT_INTERNAL_URL=ws://livekit-server.livekit.svc.cluster.local:7880
LIVEKIT_KEYS_SECRET_NAME=livekit-api-keys
K8S_LIVEKIT_NAMESPACE=livekit

# ── Letta ─────────────────────────────────────────────────────
LETTA_BASE_URL=https://letta.baisoln.com
LETTA_API_KEY=

# ── Langfuse ──────────────────────────────────────────────────
LANGFUSE_HOST=https://langfuse.bionicaisolutions.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio-tenant-hl.minio.svc.cluster.local:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_USE_SSL=false

# ── PostgreSQL Admin (for provisioning per-app databases) ─────
PG_ADMIN_URL=postgresql://postgres:postgres@pg-haproxy-primary.pg.svc.cluster.local:5432/postgres

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis-cluster.redis.svc.cluster.local:6379

# ── Webhook Base URL ──────────────────────────────────────────
WEBHOOK_BASE_URL=https://platform.baisoln.com

# ── Agent player UI (Kubernetes + optional image build) ───────
# PLAYER_UI_IMAGE=registry.example.com/player-ui:tag
# PLAYER_UI_HOST_SUFFIX=baisoln.com
# PLAYER_UI_INGRESS_CLASS=kong
# PLAYER_UI_CERT_ISSUER=letsencrypt-prod
# PLAYER_UI_SKIP_CLOUDFLARE_DNS=true   # dev only: skip Vault Cloudflare + public DNS verification
# PLAYER_UI_KONG_VERIFY_URL=http://kong-kong-proxy.kong.svc.cluster.local:80  # in-cluster Kong proxy for Host-header health check

# ── Cloudflare DNS (per-app {slug}.{PLAYER_UI_HOST_SUFFIX}) ───
# Preferred: Vault KV v2 at secret/data/shared/cloudflare (GET /v1/secret/data/shared/cloudflare)
# Override path (still under secret/data/): CLOUDFLARE_VAULT_KV_PATH=shared/cloudflare
# Keys: api_token; zone_id OR zone_name OR zone_ids (JSON map host→id); WAN_IP or wan_ip (+ dns_target_ip aliases)
# Optional vault keys: dns_proxied / proxied = "true" for orange cloud
# Env fallback (e.g. local dev): CLOUDFLARE_API_TOKEN, CLOUDFLARE_ZONE_ID|CLOUDFLARE_ZONE_NAME, PLAYER_UI_DNS_TARGET_IP
# CLOUDFLARE_DNS_PROXIED=false
