# Agent Template Environment Variables
# In production, these come from K8s ConfigMap + ExternalSecret (Vault)

APP_SLUG=test-app
AGENT_NAME=test-agent

# ── LiveKit ──────────────────────────────────────────────────────
LIVEKIT_URL=ws://livekit-server.livekit.svc.cluster.local:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Primary brain (fast, user-facing voice LLM) ─────────────────
# Providers: gpu-ai | openai | custom
# Default Qwen 3.6 35B (no-think) — best voice-latency/quality on gpu-ai.
# Use qwen3.6-35b-a3b-fp8-think for CoT-heavy tasks (slower).
LLM_PROVIDER=gpu-ai
LLM_MODEL=qwen3.6-35b-a3b-fp8
# For custom provider:
# CUSTOM_LLM_BASE_URL=http://your-endpoint/v1
# CUSTOM_LLM_API_KEY=

# ── STT/TTS ─────────────────────────────────────────────────────
# STT providers: gpu-ai | deepgram | openai
STT_PROVIDER=gpu-ai
# TTS providers: gpu-ai | cartesia | openai | elevenlabs
TTS_PROVIDER=gpu-ai
TTS_VOICE=Sudhir-IndexTTS2

# ── Secondary brain (Letta executor) ────────────────────────────
LETTA_BASE_URL=http://letta-server.letta.svc.cluster.local:8283
LETTA_AGENT_ID=
LETTA_API_KEY=
# These are informational / used by platform, not by agent runtime:
# LETTA_AGENT_NAME=
# Default: thinking variant — Letta is the reasoning arm.
# LETTA_LLM_MODEL=openai-proxy/qwen3.6-35b-a3b-fp8-think

# ── GPU-AI services ─────────────────────────────────────────────
GPU_AI_MCP_URL=http://mcp-ai-mcp-server.mcp.svc.cluster.local:8009/mcp
# Only required when the agent hits the external gateway
# (https://mcp.baisoln.com/gpu-ai/v1). In-cluster path is unauthenticated.
# GPU_AI_KEY=

# ── Avatar (talking-head) ───────────────────────────────────────
# AVATAR_ENABLED=true toggles the avatar pipeline.
# AVATAR_PROVIDER: flashhead (default) | bithuman (legacy)
# AVATAR_ENABLED=false
# AVATAR_PROVIDER=flashhead
# Shared cluster endpoint for the FlashHead engine — one per cluster.
# FLASHHEAD_ENGINE_URL=ws://flashhead-engine.flashhead.svc.cluster.local:8080/v1/session
# Default face for the avatar (https URL or absolute container path).
# Per-session override via dispatch metadata {"reference_image": "..."}.
# FLASHHEAD_REFERENCE_IMAGE=
# FLASHHEAD_AVATAR_NAME=Avatar

# ── Fallback provider keys (from Vault, not user-configurable) ──
# DEEPGRAM_API_KEY=
# OPENAI_API_KEY=
# CARTESIA_API_KEY=

# ── Langfuse observability (per-app, from Vault) ────────────────
# LANGFUSE_HOST=http://langfuse-web.langfuse.svc.cluster.local:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
